# Copy this file to .env.local and fill in the values:
#
#   cp .env.local.example .env.local
#
# .env.local is gitignored — never commit real secrets.

# Neon Postgres connection string (Neon dashboard → your project → Connect).
# Use the test DB for local development; swap in the prod URL only when needed.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Password required to access the app (entered once on /auth, stored in a cookie).
APP_PASSWORD=choose-a-team-password

# Optional secret for auth hardening.
AUTH_SECRET=any-random-string

# Vercel Blob storage for match plan images
# (Vercel dashboard → project → Storage → Blob → create/attach store,
# then copy the token from the store's settings).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
